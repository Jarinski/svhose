{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "build": {
    "env": {
      "NEXT_PUBLIC_SANITY_PROJECT_ID": "mhnx7pgn",
      "NEXT_PUBLIC_SANITY_DATASET": "production",
      "NEXT_PUBLIC_SANITY_API_VERSION": "2024-01-01"
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-fussball",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sync-tischtennis",
      "schedule": "0 7 * * *"
    }
  ]
}

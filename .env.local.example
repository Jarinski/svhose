# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# Kopiere diese Datei nach .env.local und trage die echten Werte ein.
# Die Projekt-ID und das Dataset findest du unter https://sanity.io/manage

# Pflicht: Deine Sanity-Projekt-ID (aus sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=dein-projekt-id

# Pflicht: Das Sanity-Dataset (Standard: production)
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: API-Version (ISO-Datum)
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Nur für den Migrations-Script nötig: Schreib-Token (aus Sanity-Projekt-Settings → API → Tokens)
# Typ: Editor oder Administrator
SANITY_API_WRITE_TOKEN=dein-schreib-token
